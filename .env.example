# Network Telescope - Capturing Node Environment
# Edit these values before running start.sh

PROJECT_ROOT=
DATA_DIR=
NT_HOME=
INTERFACE=eth0
DURATION=3600
RING_BUFFER_SIZE=24

# Transfer settings
TRANSFER_MODE=remote
REMOTE_USER=telescope
REMOTE_HOST=
REMOTE_DIR=/var/lib/network-telescope/data/queue
SSH_KEY_PATH=

# CPU pinning
CAPTURE_CPUS=
DETECTOR_CPUS=